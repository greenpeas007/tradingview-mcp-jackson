# === Hyperliquid Trading Bot Config ===

# Hyperliquid wallet private key (0x-prefixed)
# IMPORTANT: Use a DEDICATED trading wallet, NOT your main wallet
# Create a new wallet, transfer only trading funds to it
HL_PRIVATE_KEY=0xYOUR_DEDICATED_TRADING_WALLET_PRIVATE_KEY

# Use testnet first to verify everything works
HL_TESTNET=true

# Telegram notifications
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=353918334

# Trading config
LEVERAGE=3
RISK_PCT=10
SLIPPAGE=0.05
SL_ATR_MULT=1.5
TP_ATR_MULT=3.0

# IMPORTANT: Start with DRY_RUN=true (paper trading)
# Only set to false when you've verified on testnet
DRY_RUN=true

# Server port
PORT=3142
