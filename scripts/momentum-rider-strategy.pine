//@version=6
strategy("Momentum Rider DAILY FINAL", overlay=true, initial_capital=10000, default_qty_type=strategy.cash, default_qty_value=10000, commission_type=strategy.commission.percent, commission_value=0.1, calc_on_every_tick=true, pyramiding=3)

// === PROVEN DAILY STRATEGY — TOP PICKS: SUI, SOL, BTC, HOOD, HIMS ===

// === DATE FILTER ===
startDate = input.time(timestamp("2024-04-07"), "Start Date")
inDateRange = time >= startDate

// === RISK ===
riskPct     = input.float(15.0, "Risk % Per Trade")
maxDD       = input.float(30.0, "Max Drawdown %")
maxPosPct   = input.float(95.0, "Max Pos % Equity")

// === INDICATORS ===
emaFast = ta.ema(close, 9)
emaSlow = ta.ema(close, 21)
ema50 = ta.ema(close, 50)
rsi = ta.rsi(close, 14)
atr = ta.atr(14)
[macdLine, signalLine, hist] = ta.macd(close, 12, 26, 9)
[stValue, stDir] = ta.supertrend(2.5, 10)
volMA = ta.sma(volume, 20)

stBull = stDir < 0
emaCrossUp = ta.crossover(emaFast, emaSlow)
emaCrossDn = ta.crossunder(emaFast, emaSlow)
histCrossUp = ta.crossover(hist, 0)
rsiCross50 = ta.crossover(rsi, 50)

uptrend = emaFast > emaSlow
strongUp = uptrend and stBull

// === 6 ENTRY TYPES ===
e1 = emaCrossUp and stBull and rsi > 40 and rsi < 75
e2 = strongUp and close > emaFast and close[1] <= emaFast and rsi > 35 and rsi < 55
e3 = strongUp and histCrossUp and close > open and volume > volMA * 1.2
e4 = stBull and not stBull[1] and emaFast > emaSlow
e5 = uptrend and stBull and low <= emaSlow * 1.01 and close > emaSlow and close > open and rsi > 35
e6 = strongUp and rsiCross50 and close > emaSlow

anyBuy = inDateRange and (e1 or e2 or e3 or e4 or e5 or e6) and strategy.position_size < 3

// === DRAWDOWN ===
var float peakEq = 10000.0
if strategy.equity > peakEq
    peakEq := strategy.equity
dd = (peakEq - strategy.equity) / peakEq * 100
canTrade = dd < maxDD

// === SIZING ===
slDist = atr * 1.5
riskQty = strategy.equity * riskPct / 100 / slDist
maxQty = strategy.equity * maxPosPct / 100 / close
qty = math.min(riskQty, maxQty)

// === MANAGEMENT ===
var float sl = na
var float tp = na
var float hse = na
var float entry = na

buyFired = anyBuy and canTrade and qty > 0

if buyFired
    strategy.entry("Long", strategy.long, qty=qty)
    entry := close
    sl := close - slDist
    tp := close + atr * 3.0
    hse := close

if strategy.position_size > 0
    if high > hse
        hse := high
    if hse > entry
        trailSL = hse - atr * 1.2
        if trailSL > sl
            sl := trailSL
    strategy.exit("Exit", "Long", stop=sl, limit=tp)

if strategy.position_size > 0 and emaCrossDn and not stBull
    strategy.close("Long", comment="Rev")

// === PLOTS ===
plot(emaFast, "EMA 9", color=color.green, linewidth=1)
plot(emaSlow, "EMA 21", color=color.orange, linewidth=2)
plot(ema50, "EMA 50", color=color.blue, linewidth=2)
plot(stBull ? stValue : na, "ST", color=color.new(color.green, 50), linewidth=1, style=plot.style_linebr)
plot(strategy.position_size > 0 ? sl : na, "SL", color=color.red, style=plot.style_linebr)
plot(strategy.position_size > 0 ? tp : na, "TP", color=color.lime, style=plot.style_linebr)
plotshape(buyFired, title="Buy", text="▲", style=shape.labelup, location=location.belowbar, color=color.green, textcolor=color.white, size=size.tiny)
plotshape(strategy.position_size > 0 and emaCrossDn and not stBull, title="Sell", text="▼", style=shape.labeldown, location=location.abovebar, color=color.red, textcolor=color.white, size=size.tiny)
bgcolor(dd > maxDD * 0.7 ? color.new(color.red, 92) : na)

var table t = table.new(position.top_right, 2, 5, bgcolor=color.new(color.black, 80))
if barstate.islast
    table.cell(t, 0, 0, "Trend", text_color=color.gray, text_size=size.small)
    table.cell(t, 1, 0, strongUp ? "STRONG ↑" : uptrend ? "UP" : "DOWN", text_color=strongUp ? color.green : uptrend ? color.yellow : color.red, text_size=size.small)
    table.cell(t, 0, 1, "RSI", text_color=color.gray, text_size=size.small)
    table.cell(t, 1, 1, str.tostring(rsi, "#.0"), text_color=color.white, text_size=size.small)
    table.cell(t, 0, 2, "MACD", text_color=color.gray, text_size=size.small)
    table.cell(t, 1, 2, hist > 0 ? "+" : "-", text_color=hist > 0 ? color.green : color.red, text_size=size.small)
    table.cell(t, 0, 3, "DD", text_color=color.gray, text_size=size.small)
    table.cell(t, 1, 3, str.tostring(dd, "#.0") + "%", text_color=dd < 10 ? color.green : color.orange, text_size=size.small)
    table.cell(t, 0, 4, "Pos", text_color=color.gray, text_size=size.small)
    table.cell(t, 1, 4, str.tostring(strategy.position_size, "#.##") + "/3", text_color=color.white, text_size=size.small)
